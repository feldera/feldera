{
  "name": "profiler-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "prebuild": "bun --cwd=../.. run build:deps:profiler-app",
    "build": "bun run build:self",
    "build:self": "vite build",
    "preview": "vite preview --host",
    "check": "svelte-check --threshold error --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "format": "biome check --write ."
  },
  "dependencies": {
    "@feldera/vite-plugin-monaco-editor": "workspace:*",
    "@monaco-editor/loader": "1.7.0",
    "common-ui": "workspace:*",
    "monaco-editor": "0.55.1",
    "profiler-layout": "workspace:*",
    "profiler-lib": "workspace:*",
    "runed": "0.37.1",
    "strip-ansi": "7.1.2",
    "tiny-invariant": "1.3.3",
    "triage-types": "workspace:*",
    "virtua": "0.48.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource/dm-mono": "^5.2.7",
    "@poppanator/sveltekit-svg": "^6.0.1",
    "@skeletonlabs/skeleton": "^4.8.0",
    "@skeletonlabs/skeleton-svelte": "^4.9.0",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tailwindcss/vite": "^4.1.17",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "feldera-theme": "workspace:*",
    "svelte": "5.55.7",
    "svelte-check": "^4.3.5",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-singlefile": "^2.3.0"
  },
  "overrides": {
    "devalue": "^5.6.2"
  }
}
