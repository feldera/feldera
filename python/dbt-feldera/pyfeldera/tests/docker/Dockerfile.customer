# Stage 1: Source of precompile cache + cargo registry
FROM images.feldera.com/feldera/pipeline-manager:latest AS feldera-cache

# Stage 2: Minimal customer machine
FROM python:3.12-slim AS customer

ENV DEBIAN_FRONTEND=noninteractive

# System dependencies (bare minimum for Feldera pipeline compilation)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    openjdk-21-jre-headless \
    libssl-dev \
    pkg-config \
    libsasl2-dev \
    zlib1g-dev \
    build-essential \
    libclang-dev \
    locales \
    git \
    ca-certificates \
    golang-go \
    tzdata \
  && rm -rf /var/lib/apt/lists/*

# UTF-8 locale (needed by the Rust compiler for Unicode column names)
RUN sed -i 's/# en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen \
  && locale-gen

# Create 'ubuntu' user with UID 1000 to match official Feldera image paths
RUN useradd -m -s /bin/bash -u 1000 ubuntu
USER ubuntu
WORKDIR /home/ubuntu

# Install Rust toolchain (same version as official image)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
  | sh -s -- -y --profile minimal --default-toolchain 1.93.1

# Install mold linker for faster linking
RUN arch=$(dpkg --print-architecture | sed 's/arm64/aarch64/' | sed 's/amd64/x86_64/'); \
    curl -LO "https://github.com/rui314/mold/releases/download/v2.40.1/mold-2.40.1-${arch}-linux.tar.gz" \
    && tar -xzf "mold-2.40.1-${arch}-linux.tar.gz" \
    && mv "mold-2.40.1-${arch}-linux" /home/ubuntu/mold \
    && rm "mold-2.40.1-${arch}-linux.tar.gz"

ENV PATH="/home/ubuntu/.cargo/bin:/home/ubuntu/mold/bin:$PATH"
ENV RUSTFLAGS="-C link-arg=-fuse-ld=mold -C link-arg=-Wl,--compress-debug-sections=zlib"
ENV OPENSSL_NO_VENDOR=1
ENV OPENSSL_STATIC=1
ENV LC_ALL=en_US.UTF-8
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US:en

# Install the pyfeldera wheel
COPY --chown=ubuntu dist/*.whl /tmp/
RUN pip install --user --break-system-packages /tmp/*.whl && rm /tmp/*.whl
ENV PATH="/home/ubuntu/.local/bin:$PATH"

# Set up Feldera home at the same path as the official image
# (so the precompile cache from the official image is path-compatible)
RUN python -m pyfeldera.setup_home --target /home/ubuntu/feldera

# Copy precompile cache from the official Feldera image
COPY --from=feldera-cache --chown=ubuntu /home/ubuntu/.feldera/ /home/ubuntu/.feldera/
COPY --from=feldera-cache --chown=ubuntu /home/ubuntu/.cargo/registry/ /home/ubuntu/.cargo/registry/

# Runtime environment
ENV RUST_LOG=info
ENV RUST_BACKTRACE=1

EXPOSE 8080
CMD ["python", "-m", "pyfeldera", "--bind-address=0.0.0.0", "--feldera-home=/home/ubuntu/feldera"]
